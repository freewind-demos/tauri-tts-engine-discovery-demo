{
  "name": "tauri-tts-engine-discovery",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --open",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri",
    "build:desktop": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build",
    "build:android": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri android build --apk --ci",
    "build:android:release": "pnpm run build:android",
    "build:android:debug": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri android build --apk --ci --debug",
    "build:ios": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri ios build --ci",
    "build:macos": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target aarch64-apple-darwin",
    "build:macos:intel": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target x86_64-apple-darwin",
    "build:windows": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target x86_64-pc-windows-msvc",
    "build:windows:arm64": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target aarch64-pc-windows-msvc",
    "build:linux": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target x86_64-unknown-linux-gnu",
    "build:linux:arm64": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri build --target aarch64-unknown-linux-gnu",
    "android:build": "pnpm run build:android",
    "android:build:release": "pnpm run build:android",
    "android:build:debug": "pnpm run build:android:debug",
    "android:dev": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri android dev"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "antd": "^6.3.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
